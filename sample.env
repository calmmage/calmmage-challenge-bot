# ============================================================
#  KEY VARIABLES — you MUST set these (no sensible guesses)
# ============================================================

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Admin usernames (comma-separated; '@' optional but encouraged)
BOTSPOT_ADMINS_STR="@petrlavrov"

# MongoDB connection string — override if Mongo is not on localhost
BOTSPOT_MONGO_DATABASE_CONN_STR=mongodb://localhost:27017

# Logical DB name inside that Mongo
BOTSPOT_MONGO_DATABASE_DATABASE=sleep-challenge


# ============================================================
#  TELETHON (optional) — enables "last seen" polling
#  Uses botspot's built-in telethon_manager + /setup_telethon
#  Create api_id/api_hash at https://my.telegram.org
#  After set: admin runs /setup_telethon, pastes service phone
#  (+41772184188) and the SMS code. Session persists in ./sessions.
# ============================================================

# Leave ENABLED=false (or blank) unless BOTH api_id and api_hash are filled —
# otherwise bot startup will assert-crash inside telethon_manager.initialize().
BOTSPOT_TELETHON_MANAGER_ENABLED=false
BOTSPOT_TELETHON_MANAGER_API_ID=
BOTSPOT_TELETHON_MANAGER_API_HASH=
BOTSPOT_TELETHON_MANAGER_SESSIONS_DIR=sessions
BOTSPOT_TELETHON_MANAGER_AUTO_AUTH=true


# ============================================================
#  BOTSPOT ENABLE FLAGS (leave as-is unless you know why)
# ============================================================

BOTSPOT_MONGO_DATABASE_ENABLED=true
BOTSPOT_SCHEDULER_ENABLED=true
BOTSPOT_USER_DATA_ENABLED=true
BOTSPOT_USER_DATA_MIDDLEWARE_ENABLED=true
BOTSPOT_ASK_USER_ENABLED=true
BOTSPOT_SEND_SAFE_ENABLED=true
BOTSPOT_ERROR_HANDLER_ENABLED=true
BOTSPOT_BOT_COMMANDS_MENU_ENABLED=true
